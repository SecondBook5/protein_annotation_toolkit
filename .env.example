# Protein Annotation Toolkit - Environment Configuration
# Copy this file to .env and adjust values as needed

# ============================================================================
# Database Configuration
# ============================================================================

# For development/demo (SQLite - no setup required)
# This creates a local SQLite database file in the project root
DATABASE_URL=sqlite+aiosqlite:///./protein_annotation.db

# For production (PostgreSQL)
# Format: postgresql+psycopg://user:password@host:port/database
# DATABASE_URL=postgresql+psycopg://pat_user:pat_password@localhost:5432/protein_annotation_db

# ============================================================================
# API Configuration (Optional)
# ============================================================================

# UniProt REST API base URL (rarely needs to change)
UNIPROT_API_BASE=https://rest.uniprot.org

# KEGG REST API base URL (rarely needs to change)
KEGG_API_BASE=https://rest.kegg.jp

# NCBI BLAST API base URL (rarely needs to change)
BLAST_API_BASE=https://blast.ncbi.nlm.nih.gov/blast/Blast.cgi

# NCBI Email (required only for submitting new BLAST searches)
# NCBI requires an email address for API usage tracking
# NCBI_EMAIL=your.email@example.com

# ============================================================================
# Performance Settings
# ============================================================================

# Maximum number of concurrent API requests
MAX_CONCURRENT_REQUESTS=50

# HTTP request timeout in seconds
REQUEST_TIMEOUT=30

# Default batch size for database operations
BATCH_SIZE=100

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: 'console' for human-readable, 'json' for structured logging
LOG_FORMAT=console

# ============================================================================
# Cache Configuration (Optional)
# ============================================================================

# Redis connection URL for caching API responses
# Set to enable caching, leave commented to disable
# REDIS_URL=redis://localhost:6379/0
